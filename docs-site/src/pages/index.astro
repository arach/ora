---
import BaseLayout from "../layouts/BaseLayout.astro";
import docsJson from "../../../docs.json";

const docs = docsJson as {
  groups: Array<{
    id: string;
    title: string;
    items: Array<{
      id: string;
      title: string;
      description?: string;
      slug?: string;
    }>;
  }>;
};

const cards = docs.groups.flatMap((group) =>
  group.items.map((item) => ({
    ...item,
    groupTitle: group.title,
  })),
);
---

<BaseLayout title="Ora Docs">
  <div class="docs-index">
    <div class="docs-index-header">
      <div class="docs-kicker">Documentation</div>
      <h1>Ship text-to-speech from one runtime boundary.</h1>
      <p class="docs-description">
        Ora gives apps a stable surface for provider integration, voice discovery,
        and speech synthesis across local and remote backends. The published package
        includes ESM and CommonJS entrypoints, bundled types, and the built-in
        <code>ora-worker</code> CLI.
      </p>
      <div class="docs-hero-actions">
        <a class="docs-button docs-button-primary" href="/docs/quickstart">Quickstart</a>
        <a class="docs-button" href="https://www.npmjs.com/package/@arach/ora" target="_blank" rel="noreferrer noopener">npm package</a>
      </div>
    </div>

    <section class="docs-install-panel">
      <div>
        <div class="docs-mini-label">Install</div>
        <h2>Use Ora as a package, then run the worker only when you need it.</h2>
        <p>
          Start with the runtime in your app, add providers, and keep remote or
          host-specific inference behind the worker contract.
        </p>
      </div>

      <div class="docs-install-grid">
        <div class="docs-install-card">
          <span>Bun</span>
          <code>bun add @arach/ora</code>
        </div>
        <div class="docs-install-card">
          <span>pnpm</span>
          <code>pnpm add @arach/ora</code>
        </div>
        <div class="docs-install-card">
          <span>npm</span>
          <code>npm install @arach/ora</code>
        </div>
      </div>
    </section>

    <section class="docs-facts">
      <div class="docs-fact">
        <span>Package</span>
        <strong>ESM + CJS + d.ts</strong>
      </div>
      <div class="docs-fact">
        <span>Worker</span>
        <strong><code>ora-worker</code> CLI included</strong>
      </div>
      <div class="docs-fact">
        <span>Target</span>
        <strong>Node 18+ or Bun 1.3.5+</strong>
      </div>
    </section>

    <section class="docs-command-panel">
      <div class="docs-mini-label">Worker CLI</div>
      <pre><code>bunx ora-worker init --host 0.0.0.0 --port 4020 --token dev-secret
bunx ora-worker serve --config .ora-worker/config.json</code></pre>
    </section>

    <div class="docs-card-grid">
      {cards.map((item) => (
        <a class="docs-card" href={item.slug ?? `/docs/${item.id}`}>
          <span>{item.groupTitle}</span>
          <strong>{item.title}</strong>
          <p>{item.description ?? "Open documentation page"}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
