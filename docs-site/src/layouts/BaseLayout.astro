---
import "../styles/global.css";

const { title = "Ora Docs" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&family=Instrument+Serif:ital@0;1&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="docs-shell">
      <header class="docs-topbar">
        <div class="docs-topbar-left">
          <a class="docs-wordmark" href="/">Ora</a>
          <span class="docs-chip">Documentation</span>
        </div>
        <div class="docs-topbar-right">
          <a href="/llms.txt">llms.txt</a>
          <a href="https://www.npmjs.com/package/@arach/ora" target="_blank" rel="noreferrer noopener">npm</a>
          <a href="https://github.com/arach/ora" target="_blank" rel="noreferrer noopener">GitHub</a>
        </div>
      </header>
      <slot />
    </div>
  </body>
</html>
